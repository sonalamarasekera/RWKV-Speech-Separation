# Dockerfile.dev — training / development image
#
# Build:  docker build -f Dockerfile.dev -t rwkv-ss:dev .
# Run:    docker run --gpus all -v $(pwd)/data:/app/data \
#                   -v $(pwd)/checkpoints:/app/checkpoints rwkv-ss:dev
#
# Or just: docker compose up train

FROM python:3.10-slim

WORKDIR /app

# build-essential  — compiles pesq (source-only wheel) and any other C extensions
# libsndfile1      — C library required at runtime by the soundfile Python package
# libgomp1         — GNU OpenMP runtime required by numpy
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libsndfile1 \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies before copying source so this layer is cached
# independently — a code change won't force a full pip reinstall.
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy source into the image.
# docker-compose mounts ./src over /app/src at run time so live code changes
# are picked up immediately without rebuilding.
COPY setup.py .
COPY src/     ./src/
COPY configs/ ./configs/
COPY scripts/ ./scripts/

# Editable install so volume-mounted source changes are reflected immediately.
# --no-deps: all dependencies are already installed above.
RUN pip install --no-cache-dir --no-deps -e .

CMD ["python", "-m", "scripts.train", "--config", "configs/experiment/baseline_tf.yaml"]
